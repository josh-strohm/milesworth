# Supabase — get these from https://app.supabase.com -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe — get these from https://dashboard.stripe.com -> Developers -> API keys
VITE_STRIPE_PRICE_MONTHLY=price_xxx
VITE_STRIPE_PRICE_YEARLY=price_xxx

# For Vercel serverless functions (set in Vercel dashboard, NOT in .env.local)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
